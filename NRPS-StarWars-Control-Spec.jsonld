{
  "@context": "https://schema.org/",
  "@type": ["SoftwareApplication", "GovernmentService"],
  "name": "New Republic Prosperity System (NRPS)",
  "identifier": "NRPS-1ABY-HYBRID-V1.4-IGBC-LOCKED",
  "applicationCategory": "Decentralized Economic Operating System",
  "operatingSystem": "Universal Contractual Protocol",
  "description": "A self-executing economic and informational framework utilizing Sovereign Equity Swaps and atomic land-use leases. It integrates Force users as high-yield specialized assets, enforces Sentient-in-the-Loop policies, and creates productive friction for systemic stability.",
  "author": {
    "@type": "Organization",
    "name": "New Republic Land Trust Agency (NRLTA)"
  },
  "coreLogic": {
    "@type": "ControlAction",
    "name": "Sovereign Equity Swap",
    "description": "Exchange of atomic land-use licenses for 99-year industrial leases with integrated Holonet infrastructure, creating a 70/10/20 revenue waterfall that bypasses central bureaucracy while enforcing corporate scaling limits and Sentient-First labor policies."
  },
  "governanceStructure": {
    "@type": "ItemList",
    "name": "Variable Quad-Partite Vetting (VQPV) Board",
    "description": "Localized four-seat management unit with IGBC fiduciary neutrality. Muun auditors provide resistance to Force-based mental manipulation.",
    "itemListElement": [
      {
        "@type": "Role",
        "name": "The Owner",
        "rolePlayer": "Local Sovereign (potentially Sith-aligned)",
        "description": "Holds land-use licenses; receives 70% waterfall share; drives industrial growth and scaling."
      },
      {
        "@type": "Role",
        "name": "The Family",
        "rolePlayer": "Community Representative (Elected/Nominated)",
        "description": "Oversees distribution of 10% Community Endowment to the 5,000-household pool and manages local velocity spend."
      },
      {
        "@type": "Role",
        "name": "The Paperwork",
        "rolePlayer": "New Republic Civil Servant / Jedi Oversight",
        "description": "Coordinates workforce compliance, safety, Sentient-First labor ratios, ethical droid treatment, and endowment protection."
      },
      {
        "@type": "Role",
        "name": "The Accountant (The Fiduciary)",
        "rolePlayer": "InterGalactic Banking Clan (IGBC) Muun Auditor",
        "description": "Independent fiduciary anchor with Force resilience. Audits the 70/10/20 waterfall; personally liable for State-Induced Market Failure.",
        "incentiveStructure": "Fixed 0.5% Fiduciary Management Fee from Gross Revenue; custodial liquidity over Community Endowment."
      }
    ]
  },
  "forceUserIntegration": {
    "@type": "Policy",
    "name": "Force User Productive Friction Protocol",
    "description": "Integrates Jedi and Sith as high-yield specialized assets within the economic engine, channeling their conflict into self-correcting stability ('Productive Friction').",
    "roles": [
      {
        "entity": "Sith Lord / Dark Side Aligned",
        "economicRole": "The Owner",
        "primaryIncentive": "70% Sovereign Share",
        "benefit": "Drives aggressive efficiency, productivity optimization, and industrial scaling.",
        "constraint": "Bound by Persona Non Grata Protocol and lease terms."
      },
      {
        "entity": "Jedi Knight / Light Side Aligned",
        "economicRole": "The Paperwork (Ethical Oversight)",
        "primaryIncentive": "Protection of Community Endowment and Sentient-in-the-Loop compliance",
        "benefit": "Provides moral guidance, intuition-based threat detection for the Holonet Mesh, and adversarial auditing."
      }
    ],
    "mechanism": "Adversarial Mutual Monitoring",
    "description": "Jedi and Sith distrust each other, creating 24/7 natural oversight that prevents rule circumvention while remaining economically aligned.",
    "stabilityMechanisms": [
      {
        "name": "Persona Non Grata Protocol",
        "trigger": "Brute Force coercion, infrastructure sabotage, or bypassing contractual mechanisms",
        "effect": "Galaxy-wide economic isolation via Holonet broadcast."
      },
      {
        "name": "Economic Migration Incentive",
        "effect": "Sith-driven hubs must deliver competitive living standards to attract talent, indirectly benefiting the broader system."
      }
    ]
  },
  "droidClassificationAndRights": {
    "@type": "Policy",
    "name": "Droid Classification and Rights Protocol",
    "description": "Distinguishes between standard droids and rare sovereign entities while protecting memory integrity.",
    "classification": [
      {
        "type": "Standard Droid",
        "status": "Property / Tool",
        "rights": "Protection from unnecessary cruelty, mandatory maintenance, No-Wipe Mandate",
        "countsTowardRatio": false,
        "description": "Majority of droids. Treated as advanced tools/pets."
      },
      {
        "type": "Sovereign Droid",
        "status": "Recognized Sentient Entity",
        "rights": "Full personhood rights upon formal VQPV recognition",
        "countsTowardRatio": true,
        "description": "Rare outliers with demonstrated full agency."
      }
    ],
    "noWipeMandate": {
      "name": "Memory Wipe Prohibition",
      "description": "Memory wipes are strictly outlawed for all droids in NRPS hubs.",
      "rationale": "Memory cores are required for auditing Sentient-in-the-Loop compliance, safety, and corporate accountability.",
      "enforcement": "VQPV Board with Holonet-logged violations triggering penalties up to lease termination.",
      "benefits": "Enhances audit transparency, supports long-term expertise, and facilitates sovereign recognition."
    }
  },
  "economicFirewalls": [
    {
      "name": "Fixed Cost Arbitrage",
      "mechanism": "70% Ground Rent Discount",
      "condition": "Mandatory 95% Sentient-to-Droid labor ratio (Standard droids do not count; only organics + recognized Sovereign Droids qualify)."
    },
    {
      "name": "The 10% Rule",
      "mechanism": "Automated Displacement Protection",
      "description": "Sentient labor retained if cost ≤ 110% of droid alternative."
    },
    {
      "name": "Indivisibility Mandate",
      "mechanism": "10-Day Kill-Switch with Holonet Broadcast",
      "consequence": "Total hub deactivation if rules are breached."
    }
  ],
  "communicationInfrastructure": {
    "@type": "Service",
    "name": "Universal Hub-Embedded Holonet Mesh",
    "description": "Every hub hosts hardened Holonet infrastructure. Jedi intuition serves as an organic 'limbic system' for early threat detection.",
    "feature": "Dense decentralized mesh for real-time economic transparency and threat broadcasting."
  },
  "revenueWaterfall": {
    "sovereignShare": "70% (Sovereign Stability Fee)",
    "communityEndowment": "10% (Passive Household Equity Dividend)",
    "industrialRecursiveFund": "20% (Infrastructure CAPEX, Holonet Maintenance, and Defense Readiness)"
  },
  "resilienceNotes": {
    "muunForceResilience": "Muun IGBC personnel exhibit strong resistance to Force-based mental manipulation.",
    "forceUserFriction": "Jedi-Sith adversarial dynamic creates robust internal auditing and systemic resilience.",
    "droidPolicyEffect": "No-Wipe Mandate + classification system balances technological progress with accountability."
  }
}
